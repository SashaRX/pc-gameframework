{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "outDir": "./build/esm-temp",
    "rootDir": "./src",
    "strict": true,
    "strictPropertyInitialization": false,
    "types": ["playcanvas", "webxr"],
    "esModuleInterop": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/index.ts",
    "src/scripts/**/*"
  ]
}
